# Variáveis de ambiente obrigatórias — copie para .env e preencha antes de subir o serviço
# (nunca commite o .env com valores reais)

# Redis (cache de respostas)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWKS do Cadastro (valida o Bearer recebido na borda)
JWKS_URI=http://localhost:8080/oauth2/jwks

# URLs dos serviços downstream
SERVICO_CADASTRO_URL=http://localhost:8080
SERVICO_APP_URL=http://localhost:8081
SERVICO_LOCALIZACAO_URL=http://localhost:8082
SERVICO_MIDIA_URL=http://localhost:8083

# Cache TTL em segundos
CACHE_TTL_SEGUNDOS=60
